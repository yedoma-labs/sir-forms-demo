# Environment Configuration Example
# Copy this file to .env.local for local development

# ============================================
# Node Environment
# ============================================
# Options: development, staging, production
NODE_ENV=development

# ============================================
# API Configuration (Client-Accessible)
# ============================================
# Must start with NEXT_PUBLIC_ to be available in browser
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# ============================================
# Demo Mode (Client-Accessible)
# ============================================
# When true, forms log to console instead of making API calls
# Must start with NEXT_PUBLIC_ to be available in browser
DEMO_MODE=true

# ============================================
# Server-Only Variables (Examples)
# ============================================
# These are NOT exposed to the browser
# Remove NEXT_PUBLIC_ prefix for server-only variables

# Database connection (example)
# DATABASE_URL=postgresql://user:password@localhost:5432/mydb

# API keys (example)
# STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxx
# OPENAI_API_KEY=sk-xxxxxxxxxxxxx

# Email service (example)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# ============================================
# Notes
# ============================================
# 
# 1. NEXT_PUBLIC_ Prefix:
#    - Required for client-side access
#    - Values are embedded in browser bundle
#    - Never put secrets here!
#
# 2. Server-Only Variables:
#    - No NEXT_PUBLIC_ prefix
#    - Only available in Server Components and Server Actions
#    - Safe for API keys, database URLs, etc.
#
# 3. Environment Files:
#    - .env.local         → All environments (ignored by git)
#    - .env.development   → Development only
#    - .env.production    → Production only
#    - .env.test          → Test environment
#
# 4. Priority (highest to lowest):
#    - .env.local
#    - .env.development or .env.production
#    - .env
#
# 5. After Creating .env.local:
#    - Restart dev server (pnpm dev)
#    - Never commit .env.local to git
#    - Add all variables to env.ts schema for validation
#
# 6. Validation:
#    All environment variables must be defined in env.ts:
#    
#    export const env = createEnv({
#      schema: {
#        NODE_ENV: eg.enum(['development', 'production']),
#        NEXT_PUBLIC_API_URL: eg.url(),
#      },
#    })
#
# ============================================
